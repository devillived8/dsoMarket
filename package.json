{
  "dependencies": {
    "prettify": "^0.1.7"
  },
  "name": "vitedsomarket",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "prettier --check './**/*.{html,css,js}'",
    "write": "prettier --write './**/*.{html,css,js}'",
    "lint": "stylelint \"**/*.css\"",
    "lintfix": "stylelint \"**/*.css\" --fix",
    "checkAll": "npm run check && npm run lint",
    "fixAll": "npm run write && npm run lintfix"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "vite": "^8.0.1"
  }
}
